# --- Dev: Postgres (porta 5432) ---
POSTGRES_USER=devuser
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# --- Dev: MySQL (porta 3306) ---
MYSQL_ROOT_PASSWORD=CHANGE_ME_MYSQL_ROOT_PASSWORD

# --- Apps: Postgres per Nextcloud + Immich (porta 5433) ---
POSTGRES_APPS_PASSWORD=CHANGE_ME_POSTGRES_APPS_PASSWORD

NEXTCLOUD_DB_USER=nextcloud
NEXTCLOUD_DB_PASSWORD=CHANGE_ME_NEXTCLOUD_DB_PASSWORD

IMMICH_DB_USER=immich
IMMICH_DB_PASSWORD=CHANGE_ME_IMMICH_DB_PASSWORD

# --- Nextcloud ---
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=CHANGE_ME_NEXTCLOUD_PASSWORD

REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

VAULTWARDEN_ADMIN_TOKEN=CHANGE_ME_VAULTWARDEN_ADMIN_TOKEN

# IP del server (Tailscale o LAN).
# Tutti i servizi saranno raggiungibili via: http://<nome>.<SERVER_IP>.nip.io
# Esempio: http://nextcloud.100.123.95.105.nip.io
SERVER_IP=100.123.95.105

N8N_ENCRYPTION_KEY=CHANGE_ME_N8N_ENCRYPTION_KEY

VIKUNJA_JWT_SECRET=CHANGE_ME_VIKUNJA_JWT_SECRET
